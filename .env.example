# Upstream Polymarket trading API (FastAPI)
# Local direct access: http://127.0.0.1:8000
POLYMARKET_API_URL=http://127.0.0.1:8000
# Docker only — URL the MCP container uses to reach the API on the host machine
# DOCKER_POLYMARKET_API_URL=http://host.docker.internal:8000

# HTTP MCP server (Streamable HTTP transport)
# Bind address — use 127.0.0.1 for local direct access, 0.0.0.0 inside Docker (set by compose)
MCP_HOST=127.0.0.1
MCP_PORT=8001
# Public URL clients use to reach MCP (scheme + host/IP + port, no trailing slash)
MCP_URL=http://127.0.0.1:8001
# Optional Bearer token for remote HTTP clients (leave unset for local dev without auth)
# MCP_AUTH_TOKEN=
MCP_STATELESS_HTTP=true

# Natural-language ask router (OpenAI — server-side only, never expose in clients)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# ASK_SESSION_TTL_SECONDS=1800
# ASK_EXECUTE_CONFIDENCE=0.75
# ASK_CLARIFY_CONFIDENCE=0.4
